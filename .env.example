# PayKit core
PAYKIT_DATABASE_URL=file:./paykit.db
PAYKIT_API_KEY=                              # openssl rand -hex 32
PAYKIT_WEBHOOK_SECRET=                       # openssl rand -hex 32
PAYKIT_BASE_URL=http://localhost:3000
PAYKIT_WEBHOOK_URL_ALLOWLIST=http://localhost:3001/api/paykit-webhook

# XRPL
XRPL_NETWORK=testnet
XRPL_RPC_URL=wss://s.altnet.rippletest.net:51233
PAYKIT_MERCHANT_XRPL_ADDRESS=                # r-address (XRPL/Verification 담당이 생성)

# Xaman (없으면 mock 자동)
XAMAN_MODE=mock                              # mock | real
XAMAN_API_KEY=
XAMAN_API_SECRET=

# Demo merchant
DEMO_MERCHANT_PAYKIT_API_KEY=                # = PAYKIT_API_KEY (같은 키)
DEMO_MERCHANT_PAYKIT_WEBHOOK_SECRET=         # = PAYKIT_WEBHOOK_SECRET
DEMO_MERCHANT_BASE_URL=http://localhost:3001
